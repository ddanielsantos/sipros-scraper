# ── Scraper ───────────────────────────────────────────
SCRAPE_URL=https://www.sipros.pa.gov.br/selecoes/disponiveis
HEADLESS=true
SCRAPE_TIMEOUT_MS=60000

# ── Scheduler ─────────────────────────────────────────
SCRAPE_INTERVAL_MINUTES=30

# ── Repositório ───────────────────────────────────────
DATA_DIR=./data
DATA_FILE=./data/sipros.json

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=info
LOG_JSON=false
